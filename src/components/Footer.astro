---
---

<footer class="l-footer">
  <a href="#" class="scroll-top" aria-label="Scroll to top">
    <span class="material-icons-sharp">keyboard_arrow_up</span>
    <span>Top</span>
  </a>
</footer>

<style>
  footer {
    display: flex;
    justify-content: center;
    padding-block: var(--sp-m);
  }

  .scroll-top {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 0.5em 1em;
    background: color-mix(in srgb, var(--color-main) 10%, transparent);
    border-radius: 100px;
    color: var(--color-main);
    opacity: 0.6;
    transition: opacity 0.2s ease-out;
  }

  .scroll-top:hover,
  .scroll-top:active {
    opacity: 1;
  }

  .scroll-top .material-icons-sharp {
    font-size: 1.2em;
  }
</style>

<script>
  document.querySelector('.scroll-top')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
