---
interface Props {
  src: string;
  title?: string;
  allow?: string;
}
const { src, title, allow } = Astro.props;
---

<style>
  iframe {
    width: 854px;
    max-width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
  }
</style>

<iframe
  src={src}
  title={title ?? "Video"}
  allow={allow ?? "autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media"}
  allowfullscreen
></iframe>
